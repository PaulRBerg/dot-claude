{
  // Basic configuration for Claude Code
  // General settings, environment variables, and UI customization
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  // Disable the session recap / away summary shown when returning to a session
  "awaySummaryEnabled": false,
  // Auto-delete chat transcripts older than this many days (default if unset: 30)
  "cleanupPeriodDays": 30,
  "enableAllProjectMcpServers": true,
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "model": "fable",
  "showClearContextOnPlanAccept": true,
  "skillListingBudgetFraction": 0.02,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "spinnerTipsEnabled": true,
  "tui": "fullscreen",
  "useAutoModeDuringPlan": false,
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    // Activate MCP tool search when tool definitions exceed 5% of context (default: 10%)
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "statusLine": {
    "command": "~/.local/share/bun/bin/ccstatusline",
    "type": "command"
  }
}
