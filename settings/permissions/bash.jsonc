{
  // Bash command permissions - denied shell operations
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      // Destructive File Operations
      "Bash(chmod -R:*)",
      "Bash(chown -R:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      // Dangerous Disk Operations
      "Bash(> /dev/sda*)",
      "Bash(> /etc/*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      // Process Management
      "Bash(kill -9:*)",
      "Bash(killall:*)",
      // Git & Version Control
      "Bash(git reset --hard:*)",
      // Node.js
      "Bash(npm publish:*)",
      // System Administration
      "Bash(doas:*)",
      "Bash(passwd:*)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(systemctl:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      // System Control
      "Bash(reboot:*)",
      "Bash(shutdown:*)"
    ]
  }
}
