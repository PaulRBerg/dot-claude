{
  // Skills and commands
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill(autoresearch)",
      "Skill(bump-deps)",
      "Skill(bump-release)",
      "Skill(cli-cast)",
      "Skill(cli-gh)",
      "Skill(cli-just)",
      "Skill(code-polish)",
      "Skill(code-review)",
      "Skill(code-simplify)",
      "Skill(coingecko-api)",
      "Skill(commit)",
      "Skill(create-skill)",
      "Skill(effect-ts)",
      "Skill(evm-chains)",
      "Skill(find-skills)",
      "Skill(frontend-design)",
      "Skill(git-squash)",
      "Skill(md-docs)",
      "Skill(md-docs:init-agents)",
      "Skill(md-docs:init-readme)",
      "Skill(md-docs:update-agents)",
      "Skill(md-docs:update-all)",
      "Skill(md-docs:update-readme)",
      "Skill(playground)",
      "Skill(playwright-skill)",
      "Skill(process-cleanup)",
      "Skill(tailwind-css)",
      "Skill(vercel-composition-patterns)",
      "Skill(vercel-react-best-practices)",
      "Skill(vitest)",
      "Skill(web-design-guidelines)",
      "Skill(work)",
      "Skill(yeet)"
    ],
    "deny": [
      // Disable bundled /simplify; we use /code-simplify (and /code-polish chains it)
      "Skill(simplify)"
    ]
  }
}
