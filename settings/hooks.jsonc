{
  // Hooks configuration for Claude Code, ordered alphabetically
  // These hooks execute in response to events during Claude Code's operation
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "ai-notify event notification",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "ai-notify event permission-request",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/PostToolUse/add_plan_frontmatter.py",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "command": "ai-notify event ask-user-question",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "ai-notify event stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/UserPromptSubmit/copy_prompt_to_clipboard.py",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "ai-notify event user-prompt-submit",
            "type": "command"
          }
        ]
      }
    ]
  }
}
