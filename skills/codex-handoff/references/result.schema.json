{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "changed_files",
    "verification",
    "residual_risks",
    "blockers"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "outcome", "details"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": ["passed", "failed", "not_run"]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
